class Solution {
    public int[] sortArrayByParity(int[] nums) {
        int left = 0;
        int right = nums.length - 1;
        
        while (left < right) {
            if (nums[left] % 2 == 0) {
                left++; // Even number is in the right place
            } else if (nums[right] % 2 != 0) {
                right--; // Odd number is in the right place
            } else {
                // Swap the odd number at left with the even number at right
                int temp = nums[left];
                nums[left] = nums[right];
                nums[right] = temp;
                left++;
                right--;
            }
        }
        return nums;
    }
}
